{#case clone_context(@to_boundaries)}
  {#match false}
    <div class="flex items-center">
      <div class="flex relative z-50 items-center flex-1 gap-2">
        <div class="flex w-full flex-1 p-0">
          <Bonfire.UI.Common.OpenModalLive
            reusable_modal_id="persistent_modal"
            id="define_boundary"
            no_actions
            title_text={l("Define the activity boundary")}
            without_form
            open_btn_wrapper_class="flex flex-1 w-full"
          >
            <Bonfire.UI.Boundaries.CustomizeBoundaryLive
              id="customize_boundary_live"
              boundary_preset={@boundary_preset}
              is_customizable
              to_circles={@to_circles}
              exclude_circles={@exclude_circles}
              to_boundaries={@to_boundaries}
              verb_permissions={@verb_permissions}
              setting_boundaries={@setting_boundaries}
              hide_custom={!module_enabled?(Bonfire.UI.Boundaries.SetBoundariesLive, @__context__)}
            />
            <!-- my_acls={@my_acls} -->
            <:open_btn>
              <label class="tooltip-button border-primary/50 flex items-center gap-2 btn-xs h-[30px] btn btn-primary btn-outline font-normal">
                <Bonfire.UI.Boundaries.BoundariesPresetNameLive
                  icon_class="w-5 h-5"
                  to_circles={@to_circles}
                  exclude_circles={@exclude_circles}
                  to_boundaries={@to_boundaries}
                />
              </label>
            </:open_btn>
          </Bonfire.UI.Common.OpenModalLive>
        </div>
      </div>

      {!-- <div class="" phx-hook="Tooltip" id="popup_boundaries">
          <label class="tooltip-button border-primary/30 flex items-center gap-2 btn-xs h-[30px] btn btn-primary btn-outline font-normal">
            <Bonfire.UI.Boundaries.BoundariesPresetNameLive
              icon_class="w-5 h-5"
              to_circles={@to_circles}
              exclude_circles={@exclude_circles}
              to_boundaries={@to_boundaries}
