          </label>
          <ul
            tabindex="0"
            class="tooltip z-popover menu shadow bg-base-100 border border-base-content/10 rounded-xl p-0 w-[18rem] lg:w-[24rem] absolute top-0 left-0 hidden"
          >
            <Bonfire.UI.Boundaries.BoundariesGeneralAccessLive
              to_boundaries={@to_boundaries}
              is_customizable
              to_circles={@to_circles}
              exclude_circles={@exclude_circles}
              boundary_preset={@boundary_preset}
              hide_custom={!module_enabled?(Bonfire.UI.Boundaries.SetBoundariesLive, @__context__)}
            />

